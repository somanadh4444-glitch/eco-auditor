rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    match /waste_logs/{document} {
      // Allow read (get/list) only if authenticated and the stored userId matches request.auth.uid
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;

      // Allow create only if authenticated and the incoming userId matches request.auth.uid
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;

      // Allow update and delete only if authenticated and the existing userId matches request.auth.uid
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
