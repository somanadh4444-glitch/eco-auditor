{
  "entities": {
    "WasteLog": {
      "title": "Waste Log",
      "description": "A single community waste log entry with geolocation and physical weight.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string", "enum": ["Plastic", "E-Waste", "Organic", "Metal", "Other"] },
        "weight": { "type": "number" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "timestamp": { "type": "object" }
      },
      "required": ["category", "weight", "latitude", "longitude"]
    }
  },
  "firestore": {
    "/waste_logs/{logId}": {
      "schema": "WasteLog",
      "description": "Collection of all community waste logs."
    }
  }
}
